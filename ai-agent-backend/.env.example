# LLM (pick one provider)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Or Gemini
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Redis (chat history + long-term memory)
REDIS_URL=redis://localhost:6379/0

# SQLite users DB (created on startup)
# SQLITE_PATH=/path/to/app.db

# CORS (comma-separated). Empty = sensible dev defaults in code.
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Recent messages injected into the agent context
# CHAT_HISTORY_MAX=20
